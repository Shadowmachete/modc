int_8 glob = 1;

float_16 main(int_8 i; float_16 y = 100.0;) {
  float_16 x = 50 + 100.0 + y;

  x = x + 50;

  if (x > 10)
    x -= 5;
  else if (x == 5)
    x *= 1;
  else
    x += 2;

  while (x < 100)
    x++;

  for (int_8 i = 1; i < x; ++i)
    x -= 1;

  x += sum(sum(1, 2), y = 10);

  return x;
}

int_8 sum(int_8 x; int_8 y = 1;) {
  return x + y;
}
