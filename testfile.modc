float_16 main(int_8 i; float_16 y = 100.0;) {
  float_16 x = 100.0 + 50;

  x += 50;

  if (x > 10) {
    x -= 5;
  }

  while (x < 100) {
    x++;
  }

  for (int_8 i = 1; i < x; i++) {
    x -= 1;
  }

  x += sum(i, y = 1.0);

  return x;
}

float_16 sum(int_8 x; float_16 y = 1.0;) {
  return x + y;
}
